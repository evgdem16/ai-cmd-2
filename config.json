{
  "lm_studio": {
    "base_url": "http://192.168.0.15:1234",
    "api_key": "lm-studio",
    "model": "local-model",
    "max_tokens": 256000,
    "temperature": 0.7,
    "stream": true
  },
  "dialogs": {
    "directory": "dialogs",
    "default_name": "dialog",
    "context_limit": -1,
    "display_last_n": 10
  },
  "system_prompts_file": "system_prompts.json",
  "exports_directory": "exports",
  "logs": {
    "file": "logs/app.log",
    "level": "INFO"
  }
}
